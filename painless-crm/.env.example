# Public (browser-visible) — committed to wrangler.toml [vars] in prod
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets — set via `wrangler secret put NAME` in prod
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
CRM_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=

# Cloudflare (for `wrangler` CLI; not used by the Next app at runtime)
CLOUDFLARE_ACCOUNT_ID=075668606da58c5b96a45a075f1ca99c
CLOUDFLARE_API_TOKEN=

# Local dev
NODE_ENV=development
