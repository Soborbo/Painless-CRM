# Public (browser-visible) — committed to wrangler.toml [vars] in prod
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets — set via `wrangler secret put NAME` in prod
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
CRM_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=

# Local dev
NODE_ENV=development
